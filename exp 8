<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TechStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body{
            background-color: #f5f5f5;
        }
        .card img{
            height: 220px;
            object-fit: cover;
        }
        footer{
            background-color: #212529;
            color: white;
            padding: 20px 0;
            margin-top: 40px;
        }
    </style>
</head>
<body>  
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">TechStore</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="#">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Contact</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container mt-5">
        <h2 class="text-center mb-4">Our Products</h2>
        <div class="row g-4"> 
            <div class="col-lg-4 col-md-6 col-12">
                <div class="card shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=500" class="card-img-top" alt="Phone">
                    <div class="card-body">
                        <span class="badge bg-success mb-2">New</span>
                        <h5 class="card-title">Smart Phone</h5>
                        <p class="card-text">
                            Latest 5G smartphone with high performance.
                        </p>
                        <h6 class="text-primary">₹25,000</h6>
                        <button class="btn btn-primary mt-2"
                            data-bs-toggle="modal"
                            data-bs-target="#productModal1">
                            View Details
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 col-12">
                <div class="card shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=500" class="card-img-top" alt="Headphone">
                    <div class="card-body">
                        <span class="badge bg-danger mb-2">Sale</span>
                        <h5 class="card-title">Wireless Headphones</h5>
                        <p class="card-text">
                            Noise cancellation and premium sound quality.
                        </p>
                        <h6 class="text-primary">₹4,999</h6>
                        <button class="btn btn-primary mt-2"
                            data-bs-toggle="modal"
                            data-bs-target="#productModal2">
                            View Details
                        </button>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 col-12">
                <div class="card shadow-sm h-100">
                    <img src="https://images.unsplash.com/photo-1517336714739-489689fd1ca8?w=500" class="card-img-top" alt="Laptop">
                    <div class="card-body">
                        <span class="badge bg-warning text-dark mb-2">New</span>
                        <h5 class="card-title">Laptop</h5>
                        <p class="card-text">
                            Powerful laptop for coding and gaming.
                        </p>
                        <h6 class="text-primary">₹65,000</h6>
                        <button class="btn btn-primary mt-2"
                            data-bs-toggle="modal"
                            data-bs-target="#productModal3">
                            View Details
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="productModal1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Smart Phone</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>
                        This smartphone comes with 8GB RAM, 128GB storage,
                        5000mAh battery and advanced camera features.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="productModal2">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Wireless Headphones</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>
                        Enjoy crystal clear audio with long battery life
                        and comfortable ear cushions.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="productModal3">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Laptop</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>
                        High-speed processor, SSD storage and dedicated graphics
                        make this laptop perfect for multitasking.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
    <footer class="text-center">
        <div class="container">
            <p class="mb-2">
                ©️ 2026 TechStore. All Rights Reserved.
            </p>
            <div>
                <i class="bi bi-facebook mx-2"></i>
                <i class="bi bi-instagram mx-2"></i>
                <i class="bi bi-twitter-x mx-2"></i>
                <i class="bi bi-youtube mx-2"></i>
            </div>
        </div>
    </footer> 
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>